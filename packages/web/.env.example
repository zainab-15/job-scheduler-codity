# Base URL the dashboard calls for the API, INCLUDING the /api/v1 prefix.
# Leave this unset for local dev — Vite's dev-server proxy (vite.config.ts)
# forwards same-origin /api/v1/* requests to the API on :3000 for free.
#
# Set it only for a production build, where web and api are deployed as two
# separate Railway services (and therefore two different origins):
# VITE_API_URL=https://your-api-service.up.railway.app/api/v1
#
# Vite only inlines VITE_-prefixed vars, and only at BUILD time (`npm run
# build -w @scheduler/web`) — changing this after the static files are built
# has no effect until you rebuild.
VITE_API_URL=
