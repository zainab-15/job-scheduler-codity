# Postgres connection for the app (api + worker). Points at the compose Postgres.
DATABASE_URL=postgres://scheduler:scheduler@localhost:5432/scheduler
# Throwaway database used by the integration test suite (same server, separate DB).
TEST_DATABASE_URL=postgres://scheduler:scheduler@localhost:5432/scheduler_test
# Max connections per pg Pool. Keep workers*PG_POOL_MAX < postgres max_connections (default 100). (R10)
PG_POOL_MAX=10
# Set true for Supabase / most managed Postgres (they require TLS). Leave
# false for the local compose Postgres, which doesn't speak TLS. See DEPLOY.md.
PGSSL=false
LOG_LEVEL=info

# --- worker tuning (all *_MS validated to positive ints at boot; R16) ---
POLL_INTERVAL_MS=1000
HEARTBEAT_INTERVAL_MS=10000
LEASE_MS=30000
RECLAIM_INTERVAL_MS=5000
WORKER_CONCURRENCY=5
SHUTDOWN_GRACE_MS=25000

# --- api ---
PORT=3000
# Must be >= 32 chars (enforced at boot). Change in any real deployment. (R30)
JWT_SECRET=dev-secret-change-me-please-at-least-32-chars
# Comma-separated allowed origins for the deployed dashboard, e.g.
# https://your-web-service.up.railway.app
# Leave unset for local dev — the Vite dev proxy sidesteps CORS entirely, so
# no CORS plugin is even registered until this is set. See DEPLOY.md.
CORS_ORIGIN=
